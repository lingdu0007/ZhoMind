# =========================
# ZhoMind Backend Foundation
# =========================
# 必填项（dev/prod 必须提供）
SILICONFLOW_API_KEY=

# 选填项（有默认值）
ENV=local
APP_NAME=ZhoMind Backend
API_PREFIX=/api/v1
LOG_LEVEL=INFO

HOST=0.0.0.0
PORT=8000

# DB
DATABASE_URL=sqlite+aiosqlite:///./zhomind.db

# Queue / Worker
QUEUE_BACKEND=memory

# Milvus
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530

# Model services
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen3.5-27B
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
RERANK_MODEL=Qwen/Qwen3-Reranker-8B

# Auth
AUTH_JWT_SECRET=dev-secret-change-me
AUTH_JWT_ALGORITHM=HS256
